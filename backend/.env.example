# Reddit API credentials
# Get these at: https://www.reddit.com/prefs/apps
# Click "Create App" → choose "script" type

REDDIT_CLIENT_ID=your_14_char_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_account_password
REDDIT_USER_AGENT=PracticeSight/1.0 by u/your_reddit_username

# OpenRouter API Key (free tier Llama 2 7B)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Server config
PORT=3000
CORS_ORIGIN=https://practicesightmarketing.vercel.app

# Optional: protect admin endpoints
ADMIN_KEY=some_random_secret_key

# Optional: posting limits
MAX_POSTS_PER_DAY=3
MIN_SECONDS_BETWEEN=2
MIN_ACCOUNT_AGE_DAYS=7
